# Required for on-chain features (contract deployment, attestations)
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# AXL mesh (P2P agent communication)
# Auto-resolved per platform if not set (node-darwin-arm64, node-linux-amd64, etc.)
# Override only if you built the binary somewhere custom:
# AXL_BINARY_PATH=./axl/node-linux-amd64
KEYS_DIR=./keys

# 0G Chain contract addresses (populated after deployment)
AGENT_REGISTRY_ADDRESS=0xd07B4222D25feB1Db2d87E512Ed0Cbf88c105F3A
AUDIT_ATTESTATION_ADDRESS=0x544097E0446a42eD6A298cDe34227Da559f25011

# Optional: Etherscan API for contract source fetching by address
ETHERSCAN_API_KEY=

# Frontend: backend API URL for deployment (defaults to http://localhost:3001)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
